{
	"tasks": {
		"dev": "deno run --watch --allow-read --allow-write --allow-env --allow-sys --allow-net main.js",
		"start": "deno run --allow-read --allow-write --allow-env --allow-sys --allow-net main.js",
		"lint": "deno lint .",
		"lint:fix": "deno lint --fix .",
		"fmt": "deno fmt .",
		"fmt:check": "deno fmt --check ."
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@1",
		"@std/dotenv": "jsr:@std/dotenv@^0.225.6",
		"@std/path": "jsr:@std/path@^1.1.4",
		"discord.js": "npm:discord.js@^14.25.1",
		"mineflayer": "npm:mineflayer@^4.35.0",
		"winston": "npm:winston@^3.19.0"
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 80,
		"singleQuote": false,
		"semiColons": true,
		"proseWrap": "always",
		"include": ["**/*.{js,ts,jsx,tsx,json,md}"],
		"exclude": ["**/node_modules", "**/.git", "**/logs"]
	},
	"lint": {
		"rules": {
			"tags": ["recommended"],
			"include": ["no-unused-vars"],
			"exclude": ["no-explicit-any"]
		},
		"include": ["**/*.{js,ts,jsx,tsx}"],
		"exclude": ["**/node_modules", "**/.git", "**/logs"]
	}
}
