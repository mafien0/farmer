{
	"lsp": {
		"deno": {
			"settings": {
				"deno": {
					"enable": true,
					"lint": true,
					"unstable": true,
					"config": "./deno.json"
				}
			}
		}
	},
	"languages": {
		"JavaScript": {
			"language_servers": [
				"deno",
				"!typescript-language-server",
				"!vtsls",
				"!eslint"
			],
			"formatter": "language_server",
			"format_on_save": "on"
		},
		"TypeScript": {
			"language_servers": [
				"deno",
				"!typescript-language-server",
				"!vtsls",
				"!eslint"
			],
			"formatter": "language_server",
			"format_on_save": "on"
		},
		"TSX": {
			"language_servers": [
				"deno",
				"!typescript-language-server",
				"!vtsls",
				"!eslint"
			],
			"formatter": "language_server",
			"format_on_save": "on"
		}
	}
}
